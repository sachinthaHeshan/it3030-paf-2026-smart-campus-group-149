# Copy to .env and fill in. Do not commit .env.
NEON_DATASOURCE_URL=jdbc:postgresql://host/dbname?sslmode=require&channelBinding=require
NEON_DATASOURCE_USERNAME=your_user
NEON_DATASOURCE_PASSWORD=your_password

# JWT – use a random 256-bit (32+ char) secret
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRATION_MS=86400000

# Google OAuth 2.0 client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# CORS – comma-separated origins (or * for all)
CORS_ALLOWED_ORIGINS=*
